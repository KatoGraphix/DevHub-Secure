# ─────────────────────────────────────────────────────────────
# Vercel Environment Variables — DevHub / MINT
# Import this file via: Vercel → Project → Settings →
#   Environment Variables → Import .env
#
# Lines marked [FILL IN] require values from your Replit
# Secrets tab (or your original credential source).
# ─────────────────────────────────────────────────────────────

# ── DevHub Supabase (your main auth + tasks database) ────────
# [FILL IN] Copy from: Replit Secrets → NEXT_PUBLIC_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_URL=

# [FILL IN] Copy from: Replit Secrets → NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [FILL IN] Copy from: Replit Secrets → SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (AI task intelligence) ────────────────────────────
# [FILL IN] Copy from: Replit Secrets → OPENAI_API_KEY
OPENAI_API_KEY=

# ── External MINT Supabase database ──────────────────────────
MINT_SUPABASE_URL=https://mfxnghmuccevsxwcetej.supabase.co

